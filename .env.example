# ============================================================
# remna-device-migrator — environment configuration
# Copy this file to .env and fill in the values.
# ============================================================

# Port the proxy server will listen on.
# Clients (and your reverse proxy / nginx) should point to this port.
PORT=3100

# Full URL to your Remnawave Panel (without trailing slash).
# The migrator will forward all incoming requests to this address
# and also use it for API calls (appends /api automatically).
# Examples:
#   http://remnawave:3000      (Docker internal network)
#   https://panel.example.com  (public or LAN URL)
REMNAWAVE_PANEL_URL=http://remnawave:3000

# API token from Remnawave Panel → Settings → API Tokens.
# The token must have permissions: users:read, users:write (HWID management).
REMNAWAVE_API_TOKEN=your_api_token_here

# ============================================================
# Subscription URL pattern
# ============================================================
# Regex (JavaScript syntax) with exactly ONE capture group that
# extracts the user's short UUID from the incoming request path.
#
# Default works for the standard Remnawave subscription URL format:
#   /sub/AbCdEfGh  →  captures "AbCdEfGh"
#   /api/sub/AbCdEfGh  →  captures "AbCdEfGh"
#
# You only need to change this if your subscription URLs use a
# completely different structure.
SUB_PATH_REGEX=\/([a-zA-Z0-9_-]{4,})(?:[\/\?]|$)

# ============================================================
# Migration Rules
# ============================================================
# JSON array defining which app to migrate from and to.
#
# sourceApp: The app we are deleting devices for (e.g., "happ", "incy")
# targetApp: The app making the new request (e.g., "incy", "happ")
# platformMatching: true (delete iOS only if new is iOS) | false (delete any OS)
# enabled: true/false
#
# Example: Migrate Happ to Incy AND Incy to Happ (both ways)
# MIGRATION_RULES='[{"sourceApp":"happ","targetApp":"incy","platformMatching":true,"enabled":true},{"sourceApp":"incy","targetApp":"happ","platformMatching":true,"enabled":true}]'
MIGRATION_RULES='[{"sourceApp": "happ", "targetApp": "incy", "platformMatching": true, "enabled": true}]'

# ============================================================
# Optional / tuning
# ============================================================

# Timeout (ms) for Remnawave API calls during migration.
# If the API doesn't respond within this time the migration is
# skipped and the request is forwarded anyway.
# Default: 5000 (5 seconds)
API_TIMEOUT_MS=5000

# Set to "true" to enable dry-run mode:
# Devices are identified but NOT deleted. Useful for testing.
# Default: false
DRY_RUN=false

# Log verbosity: error | warn | info | debug
# Default: info
LOG_LEVEL=info
